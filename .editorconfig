# EditorConfig
# https://editorconfig.org

root = true

# Defaults
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

# Rust
[*.rs]
indent_size = 4
max_line_length = 120

# TOML
[*.toml]
indent_size = 4

# Solidity contracts
[*.sol]
indent_size = 4

[Makefile]
indent_style = tab
