# .env.example — copy to .env.vast and fill in values
# DO NOT commit .env.vast — it contains secrets

# ---- Vast.ai -----------------------------------------------------------------
export VAST_API_KEY=your_vastai_api_key_here

# ---- Docker registry ---------------------------------------------------------
# Full image name: registry/user/name:tag
export DOCKER_IMAGE=docker.io/youruser/zkpow-prover:latest

# ---- SSH ---------------------------------------------------------------------
export SSH_KEY_PATH=$HOME/.ssh/id_ed25519

# ---- Input data --------------------------------------------------------------
# Path to the local headers.db (258 MB) to rsync to the instance
export HEADERS_DB=./headers.db

# ---- Prover configuration (injected into the container as env vars) ----------
export NUM_HEADERS=2016
export CUDA_DEVICE_ID=0
export RUST_LOG=info
# Set GENERATE_GROTH16=1 to also produce a Groth16 proof each batch (much slower)
export GENERATE_GROTH16=0

# ---- Instance sizing ---------------------------------------------------------
export DISK_GB=80
# Override GPU search query (default targets RTX 3090 / 4090 / A6000 class):
#   compute_cap >= 860 → Ampere sm_86+ (RTX 3090, A6000, RTX 4090, etc.)
#   gpu_ram >= 24      → 24 GB VRAM minimum (SP1 recommends 24 GB)
# export GPU_QUERY='num_gpus=1 gpu_ram>=24 compute_cap>=860 reliability>0.90 rentable=true direct_port_count>=1'

# ---- Output pull loop --------------------------------------------------------
export PULL_INTERVAL=120
export LOCAL_OUTPUT_DIR=./remote_outputs
# Set to 1 to also pull logs/run.jsonl on each cycle
export PULL_LOGS=1

# ---- Build -------------------------------------------------------------------
# Set SKIP_BUILD=1 if the image is already pushed and you just want to (re-)launch
# export SKIP_BUILD=1
